# Sao chép file này thành .env và sửa giá trị nếu cần.

SECRET_KEY=please-generate-a-random-32byte-secret

# Ollama đang chạy ở local (mặc định)
OLLAMA_BASE_URL=http://localhost:11434

# Model LLM. Có thể đổi sang qwen2.5:14b, qwen2.5:3b, qwen3:8b ... tùy máy.
OLLAMA_LLM_MODEL=qwen2.5:7b

# Model embedding (cần `ollama pull nomic-embed-text` trước)
OLLAMA_EMBED_MODEL=nomic-embed-text

OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_CTX=4096

RAG_TOP_K=6
