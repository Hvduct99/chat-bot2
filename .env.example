# ======== Sao chép file này thành .env và sửa giá trị nếu cần. ========

# --- Flask ---
FLASK_ENV=production
SECRET_KEY=please-generate-a-random-32byte-secret
LOG_LEVEL=INFO

# --- Ports ---
APP_HOST_PORT=5000
OLLAMA_HOST_PORT=11434

# --- Ollama (trong Docker network: dùng tên service "ollama") ---
# Khi chạy ngoài Docker (dev local): đổi thành http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434

# Model — đổi tùy máy / RAM. qwen2.5:1.5b ~1GB (CPU OK), :3b ~2GB, :7b ~5GB (cần GPU).
OLLAMA_LLM_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_CTX=2048
OLLAMA_TIMEOUT=180

# --- RAG ---
RAG_TOP_K=6
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=80
CHROMA_COLLECTION=unireg_kb

# --- Chat ---
CHAT_MAX_HISTORY=12
CHAT_MAX_INPUT_LENGTH=1000

# --- App ---
SITE_DOMAIN=http://localhost:5000
ITEMS_PER_PAGE=15
